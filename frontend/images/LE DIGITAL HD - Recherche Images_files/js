function isChromium80(){
    try{
        var pieces = navigator.userAgent.match(/Chrom(?:e|ium)\/([0-9]+)\.([0-9]+)\.([0-9]+)\.([0-9]+)/);
        if (pieces == null || pieces.length != 5) {
            return false;
        }
        pieces = pieces.map(piece => parseInt(piece, 10));
        version =  {
            major: pieces[1],
            minor: pieces[2],
            build: pieces[3],
            patch: pieces[4]
        };
        return version.major >= 80;

    }catch (e) {
        return false;
    }
}

